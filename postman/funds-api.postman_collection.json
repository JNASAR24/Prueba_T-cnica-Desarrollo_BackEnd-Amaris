{
  "info": {
    "name": "BTG Funds API - Ordered Flow",
    "_postman_id": "9a4d62c3-1b1f-4d6a-9b62-e3e0f95b3c2b",
    "description": "Functional execution flow: login -> funds -> subscribe -> history -> cancel -> history",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Login (Get JWT)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.expect(json.token).to.be.a('string');",
              "pm.collectionVariables.set('token', json.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"documentNumber\": \"123456789\",\n  \"password\": \"ChangeMe123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "02 - List Funds",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('token') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const data = pm.response.json();",
              "pm.expect(data.length).to.be.greaterThan(0);",
              "pm.collectionVariables.set('fundId', data[0].id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/funds",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "funds"
          ]
        }
      }
    },
    {
      "name": "03 - Create Subscription",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('token') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.expect(json.id).to.be.a('string');",
              "pm.collectionVariables.set('subscriptionId', json.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fundId\": \"{{fundId}}\",\n  \"notificationChannel\": \"EMAIL\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/subscriptions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "subscriptions"
          ]
        }
      }
    },
    {
      "name": "04 - Transaction History (After Subscribe)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('token') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const arr = pm.response.json();",
              "pm.expect(Array.isArray(arr)).to.eql(true);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/transactions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "transactions"
          ]
        }
      }
    },
    {
      "name": "05 - Cancel Subscription",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('token') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.expect(json.subscriptionId).to.eql(pm.collectionVariables.get('subscriptionId'));",
              "pm.expect(json.message).to.be.a('string');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"notificationChannel\": \"SMS\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/subscriptions/{{subscriptionId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "subscriptions",
            "{{subscriptionId}}"
          ]
        }
      }
    },
    {
      "name": "06 - Transaction History (After Cancel)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('token') });"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "const arr = pm.response.json();",
              "pm.expect(Array.isArray(arr)).to.eql(true);",
              "pm.expect(arr.length).to.be.greaterThan(0);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/transactions",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "transactions"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "fundId",
      "value": "1"
    },
    {
      "key": "subscriptionId",
      "value": ""
    }
  ]
}
