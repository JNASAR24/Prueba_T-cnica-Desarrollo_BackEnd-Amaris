    "description": "Coleccion completa para probar flujo de autenticacion, fondos, suscripcion, cancelacion e historial en ambientes Local y AWS.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Links de referencia",
      "item": [
        {
          "name": "Swagger Local",
          "request": {
            "method": "GET",
            "url": "{{swaggerLocalUrl}}"
          }
        },
        {
          "name": "Swagger AWS",
          "request": {
            "method": "GET",
            "url": "{{swaggerAwsUrl}}"
          }
        },
        {
          "name": "Frontend Local",
          "request": {
            "method": "GET",
            "url": "{{frontendLocalUrl}}"
          }
        },
        {
          "name": "Frontend AWS",
          "request": {
            "method": "GET",
            "url": "{{frontendAwsUrl}}"
          }
        }
      ]
    },
    {
      "name": "Flujo Local",
      "item": [
        {
          "name": "01 - Login Local",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('localToken', body.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documentNumber\": \"123456789\",\n  \"password\": \"ChangeMe123!\"\n}"
            },
            "url": "{{baseUrlLocal}}/api/v1/auth/login"
          }
        },
        {
          "name": "02 - List Funds Local",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('localToken') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "if (data.length > 0) { pm.collectionVariables.set('localFundId', data[0].id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrlLocal}}/api/v1/funds"
          }
        },
        {
          "name": "03 - Subscribe Local",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('localToken') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('localSubscriptionId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fundId\": \"{{localFundId}}\",\n  \"notificationChannel\": \"EMAIL\"\n}"
            },
            "url": "{{baseUrlLocal}}/api/v1/subscriptions"
          }
        },
        {
          "name": "04 - Transactions Local",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('localToken') });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrlLocal}}/api/v1/transactions"
          }
        },
        {
          "name": "05 - Cancel Local",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('localToken') });"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notificationChannel\": \"SMS\"\n}"
            },
            "url": "{{baseUrlLocal}}/api/v1/subscriptions/{{localSubscriptionId}}"
          }
        }
      ]
    },
