<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="funds-api"/>
    <springProperty scope="context" name="ROOT_LEVEL" source="LOG_LEVEL_ROOT" defaultValue="INFO"/>
    <springProperty scope="context" name="APP_LEVEL" source="LOG_LEVEL_APP" defaultValue="INFO"/>

    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="ch.qos.logback.classic.PatternLayout">
                <pattern>
                    {"timestamp":"%date{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}","level":"%level","app":"${APP_NAME}","thread":"%thread","logger":"%logger{36}","message":"%replace(%replace(%replace(%msg){'(?i)password[^\\s,;]*','password=***'}){'(?i)authorization:[^\\s,;]*','authorization=***'}){'(?i)jwt[^\\s,;]*','jwt=***'}","exception":"%replace(%xException){'\n','\\n'}"}%n
                </pattern>
            </layout>
        </encoder>
    </appender>

    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <springProfile name="dev,local">
        <root level="${ROOT_LEVEL}">
            <appender-ref ref="CONSOLE_PLAIN"/>
        </root>
        <logger name="com.btg.funds" level="${APP_LEVEL}"/>
    </springProfile>

    <springProfile name="aws,prod">
        <root level="${ROOT_LEVEL}">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
        <logger name="com.btg.funds" level="${APP_LEVEL}"/>
    </springProfile>

    <springProfile name="default">
        <root level="${ROOT_LEVEL}">
            <appender-ref ref="CONSOLE_PLAIN"/>
        </root>
        <logger name="com.btg.funds" level="${APP_LEVEL}"/>
    </springProfile>
</configuration>
